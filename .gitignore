# Ignore everything by default
*

# Keep this file
!.gitignore

# Keep the generated portal page
!index.html

# Keep local law HTML files used by the portal
!laws/
!laws/**

# Keep generated module mindmap pages
!module_mindmaps/
!module_mindmaps/**

# Keep GitHub Actions workflows (Pages + offline ZIP automation)
!.github/
!.github/workflows/
!.github/workflows/**

# Keep documentation
!docs/
!docs/**
